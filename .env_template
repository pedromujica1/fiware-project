# ======================================
# CONFIGURAÇÃO BÁSICA DO DISPOSITIVO
# ======================================

# Nome único do seu dispositivo (ex: tbeam-v1)
DEVICE_ID="<seu_device_id>"

# Tipo de entidade no FIWARE (manter como LoraDevice)
ENTITY_TYPE="LoraDevice"

# ======================================
# CREDENCIAIS LORAWAN DA TTN (OBRIGATÓRIAS)
# ======================================

# Identificador da aplicação (16 caracteres hex)
APP_EUI="<seu_app_eui>"

# Identificador do dispositivo (16 caracteres hex)
DEV_EUI="<seu_dev_eui>"

# ID da aplicação no formato: nomeapp@ttn
APPLICATION_ID="<nome-da-aplicacao@ttn>"

# Chave de aplicação (32 caracteres hex)
APPLICATION_KEY="<sua_application_key>"

# ======================================
# CONFIGURAÇÃO MQTT (OBRIGATÓRIA)
# ======================================

# Endereço do servidor MQTT da TTN
APP_SERVER_HOST="<mqtt.cloud.thethings.network>"

# Usuário MQTT (mesmo do APPLICATION_ID)
APP_SERVER_USERNAME="<nome-da-aplicacao@ttn>"

# Senha MQTT (gerada na aba MQTT do TTN)
APP_SERVER_PASSWORD="<sua_senha_mqtt>"

# Provedor (manter como TTN)
PROVIDER="TTN"